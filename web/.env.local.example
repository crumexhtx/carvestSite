NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Canonical public site origin for metadata, sitemap, and robots.txt.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Plausible analytics (leave blank to disable).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional self-hosted / proxied script URL.
NEXT_PUBLIC_PLAUSIBLE_SRC=

# Soft launch defaults: free tools on, paid VIN reports off.
# Flip both of these (and backend MONETIZATION_ENABLED) when ready to charge.
NEXT_PUBLIC_MONETIZATION_ENABLED=false
NEXT_PUBLIC_WAITLIST_ENABLED=true
