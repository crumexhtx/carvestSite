OPENAI_API_KEY=
MARKETCHECK_API_KEY=

# Comma-separated frontend origins allowed to call FastAPI.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production cache: use "upstash" and provide both credentials.
# Local development defaults to a persistent SQLite cache when set to "auto".
CACHE_BACKEND=auto
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CACHE_SQLITE_PATH=

# External API resilience and cache freshness.
MARKETCHECK_TIMEOUT_SECONDS=12
MARKETCHECK_MAX_RETRIES=2
MARKETCHECK_SEARCH_TTL_SECONDS=900
MARKETCHECK_PREDICTION_TTL_SECONDS=21600
MARKETCHECK_INVENTORY_TTL_SECONDS=21600
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_RETRIES=2

# Keep nationwide sample-listing calls off during assistant research.
ASSISTANT_MARKET_LOOKUPS_WITHOUT_ZIP=false

# Free Wikipedia/reference images for assistant cards when listing photos are unavailable.
REFERENCE_IMAGE_TTL_SECONDS=2592000
REFERENCE_IMAGE_TIMEOUT_SECONDS=6
# Optional paid/demo key for imagin.studio car renders.
IMAGIN_CUSTOMER=

# Per-client limits for expensive API routes.
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=30
API_RATE_LIMIT_WINDOW_SECONDS=60

# Soft launch: keep paid VIN reports offline until traffic is steady.
# Set both backend and frontend flags to true when you roll out payments.
MONETIZATION_ENABLED=false
WAITLIST_ENABLED=true
WAITLIST_STORE_BACKEND=auto
WAITLIST_SQLITE_PATH=

# Soft-launch product feedback form.
FEEDBACK_STORE_BACKEND=auto
FEEDBACK_SQLITE_PATH=

# Paid VIN buyer reports (used when MONETIZATION_ENABLED=true).
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
BUYER_REPORT_PRICE_CENTS=1900
REPORT_STORE_BACKEND=auto
REPORT_SQLITE_PATH=
REPORT_ACCESS_SECRET=replace-with-a-long-random-secret
REPORT_DEV_UNLOCK=true

# Stripe Checkout (leave empty for local development unlock mode).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Supabase production report storage. Run supabase_schema.sql first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REPORTS_TABLE=buyer_reports

# Optional report email delivery through Resend.
RESEND_API_KEY=
REPORT_EMAIL_FROM=Carvest <reports@yourdomain.com>
